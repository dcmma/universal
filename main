    UIS.InputBegan:Connect(function(input, processed)
        if processed then return end
        local data = hotkeySettings[input.KeyCode]
        if data then
            local currentTime = tick()
            if not data.hasUsedFirstTime then
                if setclipboard then setclipboard(data.text) end
                data.hasUsedFirstTime = true
                data.lastTapTime = currentTime
                data.tapCount = 1
                return 
            end
            if (currentTime - data.lastTapTime) <= 0.5 then
                data.tapCount = data.tapCount + 1
            else
                data.tapCount = 1 
            end
            data.lastTapTime = currentTime
            if data.tapCount >= 3 then
                if setclipboard then setclipboard(data.text) end
                data.tapCount = 0 
            end
        end
    end)

